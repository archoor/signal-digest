# ===== 基础设施（部署/开发时手改）=====
ENVIRONMENT=development
DEBUG=true

# 数据库（开发 SQLite，生产换 Postgres）
DATABASE_URL=sqlite:///./signaldigest.db
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/signaldigest

# 前端跨域（逗号分隔）
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# 评论分类：过短评论不调用 LLM（有效字数阈值）
CLASSIFIER_MIN_BODY_CHARS=20

# ===== 以下由管理后台「设置」页维护，保存后自动写入本文件 =====
# 采集 / LLM / 邮件 / Notion / 外网代理 / 调度 — 请勿在此重复手填
