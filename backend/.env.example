# ===== 基础 =====
ENVIRONMENT=development
DEBUG=true

# ===== 数据库（开发 SQLite，生产换 Postgres）=====
DATABASE_URL=sqlite:///./signaldigest.db
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/signaldigest

# ===== 前端跨域（第 5.1）=====
# 允许访问 API 的前端来源，逗号分隔
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ===== 采集（第 4 章）=====
DEFAULT_COUNTRY_CODES=us
INGEST_HTTP_TIMEOUT=15
# 外网代理（采集、App 搜索等）。留空=直连；支持 socks5://user:pass@host:port
INGEST_HTTP_PROXY=
INGEST_GOOGLE_PLAY_TIMEOUT=30

# ===== LLM（第 9 章，统一走 LiteLLM）=====
LLM_MODEL=openai/gpt-4o-mini
LLM_CLASSIFIER_MODEL=openai/gpt-4o-mini
LLM_API_KEY=
LLM_API_BASE=
LLM_TIMEOUT=120

# ===== 评论分类（第 6.4 / 9.4）=====
# true 且配置了 LLM_API_KEY 才会走 LLM，否则自动降级为基于评分的规则分类
ENABLE_LLM_CLASSIFICATION=true
CLASSIFIER_BATCH_SIZE=20
CLASSIFIER_BODY_MAX_CHARS=600
CLASSIFIER_MIN_BODY_CHARS=20

# ===== 邮件（第 7.3）=====
# EMAIL_PROVIDER: smtp | resend | console（console 只打印日志，便于本地开发）
EMAIL_PROVIDER=console
EMAIL_FROM=SignalDigest <noreply@example.com>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# 587 STARTTLS 用 true；465 SSL 端口用 false
SMTP_USE_TLS=true
RESEND_API_KEY=
# 周报接收邮箱（全局统一，在管理后台设置页配置）
DIGEST_RECIPIENT_EMAIL=

# ===== Notion（第 8 章，可选）=====
# 1) 打开 https://www.notion.so/profile/integrations 创建 Internal Integration，复制 Secret
# 2) 在 Notion 新建「Weekly Reports」数据库（建议列：Name/Title、Status、Period、Report ID）
# 3) 数据库页面右上角 … → Connections → 添加你的 Integration
# 4) 复制数据库 URL 中 32 位 ID 填入 NOTION_REPORTS_DATABASE_ID
NOTION_API_KEY=
NOTION_REPORTS_DATABASE_ID=
# 列名与数据库一致；只有 Name/Title 为必需，其余留空即可
NOTION_TITLE_PROPERTY=Name
NOTION_STATUS_PROPERTY=
NOTION_PERIOD_PROPERTY=
NOTION_REPORT_ID_PROPERTY=
# 生成周报后自动推送 Notion
NOTION_AUTO_EXPORT=false

# ===== 调度（第 4.5）=====
ENABLE_SCHEDULER=true
DAILY_INGEST_HOUR=6
WEEKLY_DIGEST_WEEKDAY=0
WEEKLY_DIGEST_HOUR=8
